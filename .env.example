# =============================================================================
# open-notebook — environment template
# =============================================================================
# Copy to `.env` and fill in.  Values marked [EXTERNAL] point at a service that
# lives OUTSIDE this stack — self-host it or point at an existing endpoint, your
# choice.  Values marked [SECRET] must be generated (see DEPLOYMENT.md).
#
#   [REQUIRED] app will not start / core features break without it
#   [EXTERNAL] a service you provide (may be on another host)
#   [DOCKER]   overridden automatically by docker-compose (leave as-is when
#              running under Compose; set it for bare-metal/Slurm)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Secrets to generate  [REQUIRED] [SECRET]
# -----------------------------------------------------------------------------
# OPEN_NOTEBOOK_ENCRYPTION_KEY — Fernet key encrypting stored provider creds.
#   Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OPEN_NOTEBOOK_ENCRYPTION_KEY=
# JWT_SECRET — signs session tokens.  Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_SECONDS=3600

# First admin account (created on first boot).
ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# 2. Database — SurrealDB  [REQUIRED] [EXTERNAL/DOCKER]
# -----------------------------------------------------------------------------
# Under Docker these are overridden by docker-compose to talk to the bundled
# `surrealdb` container.  For bare-metal/Slurm, point at your SurrealDB host.
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook
SURREAL_CONNECT_ATTEMPTS=3
SURREAL_CONNECT_BACKOFF=0.5

# -----------------------------------------------------------------------------
# 3. API / Uvicorn  [DOCKER]
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=5055
API_BASE_URL=http://127.0.0.1:5055
API_RELOAD=false
API_CLIENT_TIMEOUT=600.0
API_WORKERS=4            # keep <= 4 (SQLite checkpoint store write-lock limit)
API_BACKLOG=2048
API_TIMEOUT_KEEP_ALIVE=75
START_WORKER=true        # run the surreal-commands background worker in-process
WORKER_MAX_TASKS=5

# -----------------------------------------------------------------------------
# 4. Auth / CORS  [REQUIRED]
# -----------------------------------------------------------------------------
STRICT_SECURITY=1
# Public origin(s) of the web UI (comma-separated). Used for CORS.
CORS_ALLOW_ORIGINS=https://your-domain.example.org
# Legacy single shared password (leave blank when using ADMIN_* + JWT).
OPEN_NOTEBOOK_PASSWORD=
# Optional Azure AD SSO (leave blank to disable).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/common
AZURE_REDIRECT_URI=http://localhost:5055/oauth/azure/callback

# -----------------------------------------------------------------------------
# 5. NOVA-Researcher + GPU model servers  [EXTERNAL/DOCKER]
# -----------------------------------------------------------------------------
# Under Docker these are overridden to the NOVA container names.  For
# bare-metal/Slurm point them at wherever the NOVA stack + model servers run.
NOVA_RESEARCHER_URL=http://localhost:3800
SAM3_API_URL=http://localhost:4800     # segmentation
NOMIC_SERVER_URL=http://localhost:4801 # nomic embeddings
RFDETR_API_URL=http://localhost:4802   # object detection
BGE_M3_SERVER_URL=http://localhost:4803 # BGE-M3 embeddings
CLIP_SERVER_URL=http://localhost:4804  # CLIP
WHISPER_API_URL=http://localhost:4805  # speech-to-text
BGE_M3_USE_SERVER=true
BGE_M3_TIMEOUT=120
RFDETR_CONF_THRESHOLD=0.35
WHISPER_API_TIMEOUT=1800
WHISPER_MODEL=large-v3-turbo

# -----------------------------------------------------------------------------
# 6. LLM providers  [EXTERNAL] — configure at least one
# -----------------------------------------------------------------------------
# --- Primary in-house stack — AMALIA / GEMMA served LOCALLY with vLLM ---------
# Both LLMs run on-cluster as OpenAI-compatible vLLM servers (see
# docker-compose.local-models.yml, started by `./up.sh ml`). The defaults below
# point at those containers over marinha-net — no change needed for the standard
# deployment. To use EXTERNAL endpoints instead, just replace the *_BASE_URL.
#
# The model part of *_SMART_LLM (after "openai:") MUST equal the vLLM
# --served-model-name (AMALIA_VLLM_MODEL / GEMMA_VLLM_MODEL in the compose).
#
# AMALIA (chat/report LLM).  AMALIA_PROVIDER blank = openai-compatible (vLLM).
AMALIA_PROVIDER=
AMALIA_BASE_URL=http://amalia-vllm:8000/v1
AMALIA_API_KEY=local
AMALIA_SMART_LLM=openai:carminho/AMALIA-9B-50-DPO
AMALIA_FAST_LLM=openai:carminho/AMALIA-9B-50-DPO
AMALIA_STRATEGIC_LLM=openai:carminho/AMALIA-9B-50-DPO
AMALIA_PREFETCH_DOCS=5
AMALIA_EMBEDDING=local_bge_m3:bge-m3
# GEMMA (multimodal / vision LLM) — served by vLLM (OpenAI-compatible).
GEMMA_BASE_URL=http://gemma-vllm:8000/v1
GEMMA_API_KEY=local
GEMMA_SMART_LLM=openai:google/gemma-4-31B-it
GEMMA_FAST_LLM=openai:google/gemma-4-31B-it
GEMMA_STRATEGIC_LLM=openai:google/gemma-4-31B-it
GEMMA_MODEL=google/gemma-4-31B-it
GEMMA_MULTIMODAL_TIMEOUT=600
GEMMA_MULTIMODAL_MAX_TOKENS=4096
# Ollama (optional local models, e.g. qwen3).
OLLAMA_API_BASE=http://localhost:11434
QWEN_OLLAMA_BASE_URL=http://localhost:11434/
QWEN_SMART_LLM=ollama:qwen3:8b
QWEN_FAST_LLM=ollama:qwen3:8b
QWEN_STRATEGIC_LLM=ollama:qwen3:8b

# --- Public cloud providers (optional; fill only what you use) ---------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_ENDPOINT_LLM=
AZURE_OPENAI_ENDPOINT_EMBEDDING=
AZURE_OPENAI_ENDPOINT_STT=
AZURE_OPENAI_ENDPOINT_TTS=
# Google Vertex (optional)
VERTEX_PROJECT=
VERTEX_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
# HuggingFace token — needed to pull gated model weights (e.g. pyannote).
HF_TOKEN=

# -----------------------------------------------------------------------------
# 7. Search backend — OpenSearch  [EXTERNAL]
# -----------------------------------------------------------------------------
# SEARCH_BACKEND=opensearch requires a reachable OpenSearch cluster.
SEARCH_BACKEND=opensearch
OPENSEARCH_HOST=your-opensearch-host.example.org
OPENSEARCH_PORT=443
OPENSEARCH_SCHEME=https
OPENSEARCH_URL_PREFIX=opensearch_v3
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=amalia_navy_test
NAVY_OPENSEARCH_INDEX=amalia_navy_test
OPENSEARCH_VERIFY_CERTS=true
INDEX_USER_SOURCES_TO_OPENSEARCH=false

# -----------------------------------------------------------------------------
# 8. Content processing / OCR / chunking
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50
OPEN_NOTEBOOK_CHUNK_SIZE=
OPEN_NOTEBOOK_CHUNK_OVERLAP=
TIKTOKEN_CACHE_DIR=
DOCLING_OCR_ENABLED=true
DOCLING_OCR_TIMEOUT=180
DOCLING_OCR_ENGINE=auto
DOCLING_OCR_LANGS=pt,en
DOCLING_EASYOCR_DOWNLOAD=false
GEMMA_OCR_POSTPROCESS_ENABLED=true
GEMMA_OCR_POSTPROCESS_TIMEOUT=600
GEMMA_OCR_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# 9. Vision / video analysis
# -----------------------------------------------------------------------------
VIDEO_FRAME_SAMPLE_RATE=15
VIDEO_FRAME_CONCURRENCY=4
VIDEO_CAPTION_MAX_FRAMES=8
VISION_VIDEO_OCR_MAX_FRAMES=16
VISION_VIDEO_OCR_CONCURRENCY=4
VISION_VIDEO_MAX_FRAMES=32
VISION_VIDEO_MIN_FRAMES=8
VISION_VIDEO_SECONDS_PER_FRAME=4

# -----------------------------------------------------------------------------
# 10. Chat agent router / logging
# -----------------------------------------------------------------------------
CHAT_AGENT_ROUTER_ENABLED=true
CHAT_AGENT_ROUTER_TIMEOUT=600
CHAT_AGENT_TOOL_LOG_ENABLED=true
CHAT_AGENT_TOOL_LOG_DIR=data/logs
CHAT_AGENT_TOOL_LOG_FILE=data/logs/chat_agent_tool_calls.jsonl
MAX_CHAT_CONTEXT_TOKENS=32000
CHAT_KEEP_RECENT_MESSAGES=10

# -----------------------------------------------------------------------------
# 11. Navy corpus access control
# -----------------------------------------------------------------------------
NAVY_USERS_FILE=users.json
NAVY_ACCESS_CONTROL=1
NAVY_DOCS_REFRESH_SECONDS=300

# -----------------------------------------------------------------------------
# 12. Deep-research job tunables
# -----------------------------------------------------------------------------
QUERY_REWRITE_ENABLED=true
RESEARCH_PREFETCH_TIMEOUT_SECONDS=45
RESEARCH_JOB_TIMEOUT_SECONDS=2700
RESEARCH_JOB_STALE_SECONDS=3600
RESEARCH_MAX_APP_DOCS=25
RESEARCH_MAX_APP_DOC_CHARS=12000

# -----------------------------------------------------------------------------
# 13. Chart generator (POST /api/charts/generate)
# -----------------------------------------------------------------------------
CHART_MAX_FILE_SIZE_MB=25
CHART_MAX_ROWS=100000
CHART_MAX_SERIES=6
