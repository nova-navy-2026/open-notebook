# =============================================================================
# open-notebook/.env.local  —  CLUSTER-SIDE RUNTIME OVERRIDES
# =============================================================================
# Everything a deployer might want to CHANGE lives here. Copy to `.env.local`,
# uncomment only the lines you want to override, then recreate — NO image rebuild:
#
#     cp .env.local.example .env.local
#     export COMPOSE_ENV_FILES=.env,.env.local     # see note below (run once per shell)
#     docker compose up -d                          # recreates with new values (seconds)
#
# HOW OVERRIDING WORKS (two layers, both already wired):
#   1) env_file:  the compose lists `.env` then `.env.local`, so plain app vars
#      here WIN over .env (API keys, feature flags, timeouts, …).
#   2) interpolation:  image tags, mem limits, GPU IDs and the ${VAR:-default}
#      values inside `environment:` blocks are resolved from Compose's env-file
#      chain, which by default is ONLY `.env`. Exporting
#          COMPOSE_ENV_FILES=.env,.env.local
#      (or passing `--env-file .env --env-file .env.local`) makes `.env.local`
#      win for those too. Do this AFTER the file exists, or Compose errors.
#
# NOT overridable (hard-coded in docker-compose.yml, by design):
#   • published host ports  (3675)
#   • internal SURREAL_URL  (ws://surrealdb:8000/rpc)
#   • the internal model-server URLs (nova-* container names)
# Change those by editing docker-compose.yml directly.
#
# `.env.local` is gitignored + dockerignored — safe for secrets, never shipped.
# Only UNCOMMENT what you change; commented lines fall back to `.env`.
# =============================================================================

# ── Docker infra / images (need COMPOSE_ENV_FILES) ──────────────────────────
#SURREALDB_TAG=latest
#NN_NOTEBOOK_MEM_LIMIT=12g
#SURREALDB_MEM_LIMIT=8g
#LOG_MAX_SIZE=20m
#LOG_MAX_FILE=5
# DB password (also used to (re)create the surrealdb container — keep in sync):
#SURREAL_ROOT_USER=root
#SURREAL_ROOT_PASS=change-me

# ── Secrets / admin ─────────────────────────────────────────────────────────
#OPEN_NOTEBOOK_ENCRYPTION_KEY=
#JWT_SECRET=
#JWT_EXPIRY_SECONDS=3600
#ADMIN_EMAIL=admin@example.org
#ADMIN_PASSWORD=change-me

# ── API / Uvicorn (need COMPOSE_ENV_FILES) ──────────────────────────────────
#API_WORKERS=4              # keep <= 4 (SQLite checkpoint write-lock)
#API_BACKLOG=2048
#API_TIMEOUT_KEEP_ALIVE=75
#API_CLIENT_TIMEOUT=600.0
#START_WORKER=true
#WORKER_MAX_TASKS=5

# ── Auth / CORS ─────────────────────────────────────────────────────────────
#STRICT_SECURITY=1
#CORS_ALLOW_ORIGINS=https://your-domain.example.org
#OPEN_NOTEBOOK_PASSWORD=
#JWT_MAX_SESSION_SECONDS=0
# DANGER — keep blank in production:
#ALLOW_ANONYMOUS=
#ALLOW_NAVY_USER_OVERRIDE=
# Azure AD SSO (optional):
#AZURE_CLIENT_ID=
#AZURE_CLIENT_SECRET=
#AZURE_AUTHORITY=https://login.microsoftonline.com/common
#AZURE_REDIRECT_URI=https://your-domain.example.org/oauth/callback

# ── LLM endpoints (vLLM removed — point at EXTERNAL servers) ─────────────────
#AMALIA_PROVIDER=
#AMALIA_BASE_URL=https://your-llm-host/v1
#AMALIA_API_KEY=change-me
#AMALIA_SMART_LLM=openai:carminho/AMALIA-9B-50-DPO
#AMALIA_FAST_LLM=openai:carminho/AMALIA-9B-50-DPO
#AMALIA_STRATEGIC_LLM=openai:carminho/AMALIA-9B-50-DPO
#AMALIA_PREFETCH_DOCS=5
#AMALIA_EMBEDDING=local_bge_m3:bge-m3
#GEMMA_BASE_URL=https://your-vision-host/v1
#GEMMA_API_KEY=change-me
#GEMMA_SMART_LLM=openai:google/gemma-4-31B-it
#GEMMA_FAST_LLM=openai:google/gemma-4-31B-it
#GEMMA_STRATEGIC_LLM=openai:google/gemma-4-31B-it
#GEMMA_MODEL=google/gemma-4-31B-it
#GEMMA_MULTIMODAL_TIMEOUT=600
#GEMMA_MULTIMODAL_MAX_TOKENS=4096
# Ollama (optional chat):
#OLLAMA_API_BASE=http://ollama:11434
#QWEN_SMART_LLM=ollama:qwen3:8b
# Cloud provider keys (fill only what you use):
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#GOOGLE_API_KEY=
#GEMINI_API_KEY=
#GROQ_API_KEY=
#MISTRAL_API_KEY=
#DEEPSEEK_API_KEY=
#XAI_API_KEY=
#OPENROUTER_API_KEY=
#VOYAGE_API_KEY=
#ELEVENLABS_API_KEY=
#OPENAI_COMPATIBLE_API_KEY=
#OPENAI_COMPATIBLE_BASE_URL=
#HF_TOKEN=

# ── Search — OpenSearch ─────────────────────────────────────────────────────
#SEARCH_BACKEND=opensearch
#OPENSEARCH_HOST=your-opensearch-host.example.org
#OPENSEARCH_PORT=443
#OPENSEARCH_SCHEME=https
#OPENSEARCH_URL_PREFIX=opensearch_v3
#OPENSEARCH_USER=
#OPENSEARCH_PASSWORD=
#OPENSEARCH_INDEX_PREFIX=amalia_navy_test
#NAVY_OPENSEARCH_INDEX=amalia_navy_test
#OPENSEARCH_VERIFY_CERTS=true
#INDEX_USER_SOURCES_TO_OPENSEARCH=false

# ── Model-server clients (embeddings / whisper) ─────────────────────────────
#BGE_M3_USE_SERVER=true
#BGE_M3_TIMEOUT=120
#RFDETR_CONF_THRESHOLD=0.35
#WHISPER_API_TIMEOUT=1800
#WHISPER_MODEL=large-v3-turbo

# ── Content processing / OCR / chunking ─────────────────────────────────────
#MAX_UPLOAD_SIZE_MB=50
#OPEN_NOTEBOOK_CHUNK_SIZE=
#OPEN_NOTEBOOK_CHUNK_OVERLAP=
#DOCLING_OCR_ENABLED=true
#DOCLING_OCR_TIMEOUT=180
#DOCLING_OCR_ENGINE=auto
#DOCLING_OCR_LANGS=pt,en
#DOCLING_EASYOCR_DOWNLOAD=false
#GEMMA_OCR_POSTPROCESS_ENABLED=true
#GEMMA_OCR_POSTPROCESS_TIMEOUT=600
#GEMMA_OCR_MAX_TOKENS=4096

# ── Vision / video analysis ─────────────────────────────────────────────────
#VIDEO_FRAME_SAMPLE_RATE=15
#VIDEO_FRAME_CONCURRENCY=4
#VIDEO_CAPTION_MAX_FRAMES=8
#VISION_VIDEO_OCR_MAX_FRAMES=16
#VISION_VIDEO_OCR_CONCURRENCY=4
#VISION_VIDEO_MAX_FRAMES=32
#VISION_VIDEO_MIN_FRAMES=8
#VISION_VIDEO_SECONDS_PER_FRAME=4

# ── Chat agent router / context ─────────────────────────────────────────────
#CHAT_AGENT_ROUTER_ENABLED=true
#CHAT_AGENT_ROUTER_TIMEOUT=600
#CHAT_AGENT_TOOL_LOG_ENABLED=true
#MAX_CHAT_CONTEXT_TOKENS=32000
#CHAT_KEEP_RECENT_MESSAGES=10

# ── Navy corpus access control ──────────────────────────────────────────────
#NAVY_USERS_FILE=users.json
#NAVY_ACCESS_CONTROL=1
#NAVY_DOCS_REFRESH_SECONDS=300

# ── Deep-research job tunables ──────────────────────────────────────────────
#QUERY_REWRITE_ENABLED=true
#RESEARCH_PREFETCH_TIMEOUT_SECONDS=45
#RESEARCH_JOB_TIMEOUT_SECONDS=2700
#RESEARCH_JOB_STALE_SECONDS=3600
#RESEARCH_MAX_APP_DOCS=25
#RESEARCH_MAX_APP_DOC_CHARS=12000

# ── Chart generator (need COMPOSE_ENV_FILES) ────────────────────────────────
#CHART_MAX_FILE_SIZE_MB=25
#CHART_MAX_ROWS=100000
#CHART_MAX_SERIES=6
